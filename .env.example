#################################################
# OpenForge — Environment Configuration
#################################################
# Copy this file to .env (or .env.local) and
# fill in the required values.
#
#   Linux/macOS:  cp .env.example .env
#   Windows:      Copy-Item .env.example .env
#################################################


#################################################
# Application
#################################################

# Environment mode: development | production | test
NODE_ENV=development


#################################################
# GitHub
#################################################

# Required — GitHub Personal Access Token
# Create one at: https://github.com/settings/tokens
# Scopes needed: public_repo (read-only access)
GITHUB_TOKEN=<your_github_personal_access_token>

# GitHub API endpoints (defaults are usually fine)
GITHUB_API_URL=https://api.github.com/graphql
GITHUB_REST_API_URL=https://api.github.com

# Optional — User-Agent header for GitHub requests
GITHUB_USER_AGENT=OpenForge


#################################################
# AI / Ollama
#################################################

# Ollama server URL (must be running locally)
# Install: https://ollama.com/download
OLLAMA_BASE_URL=http://localhost:11434

# Chat model for conversational AI features
# Pull with: ollama pull qwen3:8b
OLLAMA_CHAT_MODEL=qwen3:8b

# Summary model for text summarization
# Pull with: ollama pull gemma3:latest
OLLAMA_SUMMARY_MODEL=gemma3:latest

# Embedding model for vector operations
# Pull with: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Request timeout in milliseconds
OLLAMA_TIMEOUT=120000


#################################################
# Cache
#################################################

# Enable or disable in-memory caching (true | false)
CACHE_ENABLED=true

# Cache time-to-live in seconds
CACHE_TTL=3600


#################################################
# Repository Analysis
#################################################

# Maximum number of files to process per repository
MAX_REPOSITORY_FILES=10000

# Maximum directory traversal depth
MAX_REPOSITORY_DEPTH=8


#################################################
# Search
#################################################

# Number of results per page
SEARCH_PAGE_SIZE=20

# Maximum total search results
SEARCH_MAX_RESULTS=100


#################################################
# Logging
#################################################

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable debug mode (true | false)
DEBUG_MODE=false