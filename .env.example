GITHUB_TOKEN=your_github_personal_access_token_here
OLLAMA_BASE_URL=http://localhost:11434


# ======================================================
# OpenForge
# ======================================================

NODE_ENV=development

APP_NAME=OpenForge
APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ======================================================
# GitHub
# ======================================================

GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com/graphql
GITHUB_REST_API_URL=https://api.github.com

# Optional
GITHUB_USER_AGENT=OpenForge

# ======================================================
# AI (Ollama)
# ======================================================

OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_CHAT_MODEL=qwen3:8b

OLLAMA_SUMMARY_MODEL=gemma3:latest

OLLAMA_EMBEDDING_MODEL=nomic-embed-text

OLLAMA_TIMEOUT=120000

# ======================================================
# Cache
# ======================================================

CACHE_ENABLED=true
CACHE_TTL=3600

# ======================================================
# Repository Analysis
# ======================================================

MAX_REPOSITORY_FILES=10000
MAX_REPOSITORY_DEPTH=8

# ======================================================
# Search
# ======================================================

SEARCH_PAGE_SIZE=20

SEARCH_MAX_RESULTS=100

# ======================================================
# Recommendation Engine
# ======================================================

RECOMMENDATION_CACHE=true

RECOMMENDATION_CACHE_TTL=3600

# ======================================================
# Repository Intelligence
# ======================================================

INTELLIGENCE_CACHE=true

INTELLIGENCE_CACHE_TTL=3600

# ======================================================
# Mentor
# ======================================================

MENTOR_CACHE=true

MENTOR_CACHE_TTL=3600

# ======================================================
# Logging
# ======================================================

LOG_LEVEL=info

DEBUG_MODE=false