{
  "name": "openforge-monorepo",
  "packageManager": "npm@10.2.4",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck test",
    "validate": "turbo run lint typecheck test build",
    "clean": "turbo run clean",
    "bench": "turbo run benchmark:recommendations benchmark:health --filter=@openforge/benchmarks",
    "e2e": "npx playwright test --config=apps/web/playwright.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "turbo": "latest",
    "typescript": "^5.4.5"
  }
}
