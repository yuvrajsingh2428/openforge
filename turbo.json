{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "GITHUB_TOKEN",
    "GITHUB_API_URL",
    "GITHUB_REST_API_URL",
    "OLLAMA_BASE_URL",
    "OLLAMA_CHAT_MODEL",
    "OLLAMA_SUMMARY_MODEL",
    "OLLAMA_EMBEDDING_MODEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
